<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".FirebaseSyncActivity">

    <!-- Thanh trạng thái online/offline (đổi màu trong code) -->
    <TextView
        android:id="@+id/tvFbStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#C62828"
        android:padding="12dp"
        android:text="@string/str_fb_offline"
        android:textColor="#FFFFFF"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <EditText
            android:id="@+id/etFbName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/str_fb_name_hint"
            android:inputType="textPersonName" />

        <EditText
            android:id="@+id/etFbEmail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/str_fb_email_hint"
            android:inputType="textEmailAddress" />

        <EditText
            android:id="@+id/etFbPhone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/str_fb_phone_hint"
            android:inputType="phone" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnFbSave"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/str_fb_add" />

            <Button
                android:id="@+id/btnFbDelete"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="@string/str_fb_delete" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnFbSeed"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/str_fb_seed" />

            <Button
                android:id="@+id/btnFbSync"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="@string/str_fb_sync" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/tvFbCount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="6dp"
        android:textColor="#616161"
        android:textStyle="bold" />

    <ListView
        android:id="@+id/lvFbContacts"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="#EEEEEE"
        android:dividerHeight="1dp" />
</LinearLayout>
